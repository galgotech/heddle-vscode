{
    "comments": {
        "lineComment": "//",
        "blockComment": [
            "/*",
            "*/"
        ]
    },
    "brackets": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ]
    ],
    "autoClosingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "\"",
            "\""
        ],
        [
            "'",
            "'"
        ],
        [
            "<",
            ">"
        ]
    ],
    "surroundingPairs": [
        [
            "{",
            "}"
        ],
        [
            "[",
            "]"
        ],
        [
            "(",
            ")"
        ],
        [
            "\"",
            "\""
        ],
        [
            "'",
            "'"
        ],
        [
            "<",
            ">"
        ]
    ],
    "onEnterRules": [
        {
            "beforeText": "^\\s*$",
            "action": {
                "indent": "outdent"
            }
        }
    ],
    "indentationRules": {
        "increaseIndentPattern": "^.*(\\{|\\(|\\.|->|\\|)\\s*$",
        "decreaseIndentPattern": "^\\s*(\\}|\\)).*$"
    }
}