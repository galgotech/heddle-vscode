{
    "scopeName": "source.heddle",
    "name": "Heddle",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#prql"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#punctuation"
        },
        {
            "include": "#identifiers"
        }
    ],
    "repository": {
        "prql": {
            "begin": "\\(",
            "end": "\\)",
            "patterns": [
                {
                    "include": "source.prql"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.object.property.heddle",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=:)"
                },
                {
                    "name": "variable.name.heddle",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)*\\b"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.definition.heddle",
                    "match": "[\\{\\}\\[\\]\\(\\),:;=]"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.heddle",
                    "match": "\\b(import|resource|schema|step|handler|workflow|let|true|false|null)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.heddle",
                    "match": "\\b(int|string|float|bool|timestamp)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.heddle",
                    "match": "(\\||->|\\?)"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.heddle",
                    "match": "//.*"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.heddle",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.heddle",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.heddle",
                    "match": "\\b-?[0-9]+(\\.[0-9]+)?\\b"
                }
            ]
        }
    }
}