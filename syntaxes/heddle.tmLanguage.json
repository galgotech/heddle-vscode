{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Heddle",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#prql"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.heddle",
				"match": "\\b(if|while|for|return)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.heddle",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.heddle",
					"match": "\\\\."
				}
			]
		},
		"prql": {
            "name": "string.unquoted.prql.heddle",
            "begin": "\\(",
            "end": "\\)",
            "contentName": "source.prql"
        }
	},
	"scopeName": "source.heddle"
}