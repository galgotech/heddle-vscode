{
  "name": "heddle-language",
  "displayName": "Heddle Language",
  "description": "Language support for the heddle language",
  "publisher": "galgotech",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Data Science",
    "Formatters",
    "Programming Languages"
  ],
  "keywords": [
    "data tools",
    "functional programming",
    "workflow",
    "pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/galgotech/heddle-vscode.git"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:heddle"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish"
  },
  "contributes": {
    "languages": [
      {
        "id": "heddle",
        "aliases": [
          "Heddle",
          "heddle",
          "he"
        ],
        "extensions": [
          ".he"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "heddle",
        "scopeName": "source.heddle",
        "path": "./syntaxes/heddle.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[heddle]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.formatOnType": true
      }
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/vscode": "^1.104.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}