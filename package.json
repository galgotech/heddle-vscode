{
  "name": "heddle-language",
  "displayName": "Heddle Language",
  "description": "Language support for the heddle language",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Data Science",
    "Formatters",
    "Programming Languages"
  ],
  "keywords": [
    "data tools",
    "functional programming",
    "workflow",
    "pipeline"
  ],
  "contributes": {
    "languages": [{
      "id": "heddle",
      "aliases": ["Heddle", "heddle", "he"],
      "extensions": [".he"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "heddle",
      "scopeName": "source.heddle",
      "path": "./syntaxes/heddle.tmLanguage.json"
    }],
    "configuration": {
      "title": "Heddle Configuration",
      "type": "object",
      "properties": {
        "[heddle]": {
          "editor.tabSize": 2,
          "editor.insertSpaces": true
        }
      }
    },
    "configurationDefaults": {
      "[heddle]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      }
    }
  }
}
