{
  "name": "heddle-language",
  "displayName": "Heddle Language",
  "description": "Language support for the heddle language",
  "publisher": "galgotech",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Data Science",
    "Formatters",
    "Programming Languages"
  ],
  "keywords": [
    "data tools",
    "functional programming",
    "workflow",
    "pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/galgotech/heddle-vscode.git"
  },
  "scripts": {
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish"
  },
  "contributes": {
    "languages": [
      {
        "id": "heddle",
        "aliases": [
          "Heddle",
          "heddle",
          "he"
        ],
        "extensions": [
          ".he"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "heddle",
        "scopeName": "source.heddle",
        "path": "./syntaxes/heddle.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Heddle Configuration",
      "type": "object",
      "properties": {
        "[heddle]": {
          "editor.tabSize": 2,
          "editor.insertSpaces": true
        }
      }
    },
    "configurationDefaults": {
      "[heddle]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
      }
    }
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}